# Supabase (public — safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Newer Supabase dashboards call this the "publishable" key (it's the anon key).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Older dashboards use this name instead — supported as a fallback.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin — fixed credentials for the panel (no account creation needed).
ADMIN_EMAIL=admin@b202.dev
ADMIN_PASSWORD=b202admin

# Supabase service_role key (SECRET — server only, never exposed to browser).
# Required so the admin panel can insert/update/delete despite Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


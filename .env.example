# Supabase (public ‚Äî safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Newer Supabase dashboards call this the "publishable" key (it's the anon key).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Older dashboards use this name instead ‚Äî supported as a fallback.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin ‚Äî fixed credentials for the panel (no account creation needed).
ADMIN_EMAIL=admin@b202.dev
ADMIN_PASSWORD=b202admin

# Supabase service_role key (SECRET ‚Äî server only, never exposed to browser).
# Required so the admin panel can insert/update/delete despite Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# Session HMAC secret (SECRET ó server only). Generate a random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=change-me-to-a-random-secret
